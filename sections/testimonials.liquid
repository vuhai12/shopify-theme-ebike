<section class="bg-white py-16">
  <div class="container mx-auto px-6">
    <!-- heading -->

    <div class="text-center max-w-2xl mx-auto mb-12">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">
        {{ section.settings.title }}
      </h2>

      <p class="text-gray-600">
        {{ section.settings.description }}
      </p>
    </div>

    <!-- testimonials grid -->

    <div class="grid md:grid-cols-3 gap-8">
      {% if section.blocks.size == 0 %}
        <!-- fallback testimonials -->

        {% assign names = 'John Smith|Sarah Johnson|David Lee' | split: '|' %}
        {% assign roles = 'Fashion Store Owner|Electronics Merchant|Dropshipping Brand Owner' | split: '|' %}
        {% assign reviews = 'This theme helped me launch my store in just one day. Super flexible and fast!'
          | append: '|'
          | append: 'Beautiful layout and very easy to customize. Highly recommended.'
          | append: '|'
          | append: 'Customer support is amazing. The theme works perfectly with my apps.'
          | split: '|'
        %}

        {% for review in reviews %}
          <div class="border rounded-xl p-6 shadow-sm">
            <!-- stars -->

            <div class="flex mb-4 text-yellow-400">
              {% for i in (1..5) %}
                ★
              {% endfor %}
            </div>

            <!-- review -->

            <p class="text-gray-700 mb-6">"{{ review }}"</p>

            <!-- user -->

            <div>
              <p class="font-semibold">
                {{ names[forloop.index0] }}
              </p>

              <p class="text-sm text-gray-500">
                {{ roles[forloop.index0] }}
              </p>
            </div>
          </div>
        {% endfor %}

      {% else %}
        {% for block in section.blocks %}
          <div class="border rounded-xl p-6 shadow-sm">
            <!-- stars -->

            <div class="flex mb-4 text-yellow-400">
              {% for i in (1..block.settings.rating) %}
                ★
              {% endfor %}
            </div>

            <!-- review text -->

            <p class="text-gray-700 mb-6">"{{ block.settings.review }}"</p>

            <!-- user info -->

            <div class="flex items-center gap-4">
              {% if block.settings.avatar != blank %}
                <img
                  height=""
                  width=""
                  src="{{ block.settings.avatar | image_url }}"
                  class="w-12 h-12 rounded-full object-cover"
                >
              {% endif %}

              <div>
                <p class="font-semibold">
                  {{ block.settings.name }}
                </p>

                <p class="text-sm text-gray-500">
                  {{ block.settings.role }}
                </p>
              </div>
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section title",
      "default": "Loved by Merchants Worldwide"
    },

    {
      "type": "textarea",
      "id": "description",
      "label": "Section description",
      "default": "Thousands of store owners trust our Shopify themes to build fast and professional storefronts."
    }
  ],

  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "image_picker",
          "id": "avatar",
          "label": "Avatar"
        },

        {
          "type": "text",
          "id": "name",
          "label": "Customer name",
          "default": "Customer name"
        },

        {
          "type": "text",
          "id": "role",
          "label": "Customer role",
          "default": "Store owner"
        },

        {
          "type": "textarea",
          "id": "review",
          "label": "Review text",
          "default": "Amazing Shopify theme! Easy to customize and very fast."
        },

        {
          "type": "range",
          "id": "rating",
          "label": "Rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        }
      ]
    }
  ],

  "max_blocks": 6,

  "presets": [
    {
      "name": "Testimonials",
      "blocks": [{ "type": "testimonial" }, { "type": "testimonial" }, { "type": "testimonial" }]
    }
  ]
}
{% endschema %}
