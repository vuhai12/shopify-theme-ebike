<section class="container mx-auto py-12">
  <h3 class="text-3xl font-bold text-center mb-14">How It Works</h3>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-[30px]">
    {% if section.blocks.size == 0 %}
      <div class="flex-1 text-center p-6 border border-gray-200 rounded-lg flex flex-col items-center gap-5">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="mx-auto mb-4 w-12 h-12 text-purple-400"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="1.5"
        >
          <path d="M12 3a9 9 0 1 0 0 18c1.1 0 2-.9 2-2 0-.6-.2-1.1-.6-1.5-.4-.4-.6-.9-.6-1.5 0-1.1.9-2 2-2h1a4 4 0 0 0 4-4 9 9 0 0 0-9-7z"/>
          <circle cx="7.5" cy="10.5" r="1"/>
          <circle cx="10.5" cy="7.5" r="1"/>
          <circle cx="14.5" cy="7.5" r="1"/>
        </svg>
        <h3 class="text-xl font-semibold mb-2">Choose a Theme</h3>
        <p class="text-gray-600">Pick a modern Shopify theme that matches your brand.</p>
      </div>

      <div class="flex-1 text-center p-6 border border-gray-200 rounded-lg flex flex-col items-center gap-5">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="mx-auto mb-4 w-12 h-12 text-purple-400"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="1.5"
        >
          <line x1="4" y1="21" x2="4" y2="14"/>
          <line x1="4" y1="10" x2="4" y2="3"/>
          <line x1="12" y1="21" x2="12" y2="12"/>
          <line x1="12" y1="8" x2="12" y2="3"/>
          <line x1="20" y1="21" x2="20" y2="16"/>
          <line x1="20" y1="12" x2="20" y2="3"/>
          <line x1="1" y1="14" x2="7" y2="14"/>
          <line x1="9" y1="8" x2="15" y2="8"/>
          <line x1="17" y1="16" x2="23" y2="16"/>
        </svg>
        <h3 class="text-xl font-semibold mb-2">Customize Layout</h3>
        <p class="text-gray-600">Adjust colors, fonts, and layout without coding.</p>
      </div>

      <div class="flex-1 text-center p-6 border border-gray-200 rounded-lg flex flex-col items-center gap-5">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="mx-auto mb-4 w-12 h-12 text-purple-400"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="1.5"
        >
          <path d="M21 8l-9-5-9 5 9 5 9-5z"/>
          <path d="M3 8v8l9 5 9-5V8"/>
          <path d="M12 13v8"/>
        </svg>
        <h3 class="text-xl font-semibold mb-2">Add Products</h3>
        <p class="text-gray-600">Import your products and organize collections easily.</p>
      </div>

      <div class="flex-1 text-center p-6 border border-gray-200 rounded-lg flex flex-col items-center gap-5">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="mx-auto mb-4 w-12 h-12 text-purple-400"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="1.5"
        >
          <path d="M4.5 16.5L3 21l4.5-1.5L19 8l-3-3L4.5 16.5z"/>
          <path d="M14 5l3 3"/>
        </svg>
        <h3 class="text-xl font-semibold mb-2">Launch Store</h3>
        <p class="text-gray-600">Publish your store and start selling instantly.</p>
      </div>
    {% else %}
      {% for block in section.blocks %}
        <div class="flex-1 text-center p-6 border border-gray-200 rounded-lg">
          {% if block.settings.icon %}
            <img
              width=""
              height=""
              src="{{ block.settings.icon | image_url }}"
              alt="{{ block.settings.title }}"
              class="mx-auto mb-4 w-12 h-12"
            >
          {% endif %}
          <h3 class="text-xl font-semibold mb-2">{{ block.settings.title }}</h3>
          <p class="text-gray-600">{{ block.settings.description }}</p>
        </div>
      {% endfor %}
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "How It Works",
  "settings": [],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "How It Works",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "title": "Choose a Theme",
            "description": "Pick a modern Shopify theme that matches your brand."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Customize Layout",
            "description": "Adjust colors, fonts, and layout without coding."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Add Products",
            "description": "Import your products and organize collections easily."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Launch Store",
            "description": "Publish your store and start selling instantly."
          }
        }
      ]
    }
  ]
}
{% endschema %}
